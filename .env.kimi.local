# Local Gemini AI Studio config for AstroScout backend.
# This file is gitignored. Keep it local only.

# Google AI Studio key
ASTROSCOUT_OPENAI_API_KEY=your_gemini_ai_studio_key

# Gemini OpenAI-compatible endpoint
ASTROSCOUT_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
ASTROSCOUT_OPENAI_COMPLETIONS_PATH=/chat/completions

# Free-capable model for POC/dev
ASTROSCOUT_OPENAI_MODEL=gemini-2.0-flash-exp
